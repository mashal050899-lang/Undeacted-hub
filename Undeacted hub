-- Toggle animation helper
local function animateToggle(isOn, track, knob)
    local tweenOn = TI(0.15, Enum.EasingStyle.Linear)
    local tweenBack = TI(0.15, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    if isOn then
        TweenService:Create(track, tweenOn, { BackgroundColor3 = COL_TOGGLE_ON }):Play()
        TweenService:Create(knob, tweenBack, {
            BackgroundColor3 = COL_KNOB_ON,
            Position         = UD2(1, -18, 0.5, -8),
        }):Play()
    else
        TweenService:Create(track, tweenOn, { BackgroundColor3 = COL_TOGGLE_OFF }):Play()
        TweenService:Create(knob, tweenBack, {
            BackgroundColor3 = COL_KNOB_OFF,
            Position         = UD2(0, 2, 0.5, -8),
        }):Play()
    end
end

