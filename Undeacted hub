----------------------------------------------------------------------
-- BatLock logic
----------------------------------------------------------------------
local BatLockPart = nil
local BatLockConn = nil
local BatLockJumpConn = nil

local function disableBatLock()
    if BatLockPart then BatLockPart:Destroy(); BatLockPart = nil end
    if BatLockConn then BatLockConn:Disconnect(); BatLockConn = nil end
    if BatLockJumpConn then BatLockJumpConn:Disconnect(); BatLockJumpConn = nil end
    TweenService:Create(BatBtnIndicator, TI(0.2), { BackgroundColor3 = COL_TOGGLE_OFF }):Play()
    TweenService:Create(BatBtnStroke,    TI(0.2), { Color             = COL_BORDER }):Play()
end

BatBtnHitbox.MouseButton1Click:Connect(function()
    if BatLockConn then
        disableBatLock()
        return
    end

    -- Create locking cylinder in workspace
    pcall(function()
        Character = LocalPlayer.Character
        if not Character then return end
        if not Character:FindFirstChild("HumanoidRootPart") then return end

        BatLockPart           = Instance.new("Part")
        BatLockPart.Shape     = Enum.PartType.Cylinder
        BatLockPart.Size      = Vector3.new(0.2, 8, 8)
        BatLockPart.Anchored  = true
        BatLockPart.CanCollide= false
        BatLockPart.CastShadow= false
        BatLockPart.Material  = Enum.Material.Neon
        BatLockPart.Color     = COL_WHITE
        BatLockPart.Transparency = 0.5
        BatLockPart.Parent    = workspace

        -- Lock position on Heartbeat
        BatLockConn = RunService.Heartbeat:Connect(function()
            pcall(function()
                local root = Character and Character:FindFirstChild("HumanoidRootPart")
                if root and BatLockPart then
                    BatLockPart.CFrame = root.CFrame * CFrame.Angles(0, 0, math.pi / 2)
                end
            end)
        end)

        -- Suppress jump while BatLock is active
        BatLockJumpConn = UserInputService.JumpRequest:Connect(function()
            pcall(function()
                if not Character then return end
                local hum = Character:FindFirstChildOfClass("Humanoid")
                if hum then hum:ChangeState(Enum.HumanoidStateType.Seated) end
            end)
        end)

        -- Equip the bat/tool if in backpack
        pcall(function()
            local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
            if not backpack then return end
            local hum = Character:FindFirstChildOfClass("Humanoid")
            if not hum then return end
            for _, child in ipairs(Character:GetChildren()) do
                if child:IsA("Tool") then hum:EquipTool(child) end
            end
        end)

        -- Indicator animations
        TweenService:Create(BatBtnIndicator, TI(0.2), { BackgroundColor3 = COL_GREEN }):Play()
        TweenService:Create(BatBtnStroke,    TI(0.2), { Color             = COL_WHITE }):Play()
    end)
end)

-- BatBtn drag
do
    local dragging, dragStart, startPos
    BatBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging  = true
            dragStart = input.Position
            startPos  = BatBtn.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if not dragging then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch then
            local delta = input.Position - dragStart
            BatBtn.Position = UD2(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

----------------------------------------------------------------------
-- Toggle: ESP
----------------------------------------------------------------------
local function removeESP(player)
    if ESPObjects[player] then
        for _, obj in pairs(ESPObjects[player]) do
            pcall(function() obj:Destroy() end)
        end
        ESPObjects[player] = nil
    end
end

local function addESP(player)
    if player == LocalPlayer then return end
    removeESP(player)
    ESPObjects[player] = {}

    local function buildForChar(char)
        if not char then return end
        local hl = Instance.new("SelectionBox")
        hl.Color3           = COL_WHITE
        hl.LineThickness    = 0.05
        hl.SurfaceTransparency = 0.8
        hl.Adornee          = char
        hl.Parent           = ScreenGui
        ESPObjects[player].highlight = hl

        -- Billboard name tag above head
        local head = char:WaitForChild("Head", 5)
        if not head then return end

        local bb = Instance.new("BillboardGui")
        bb.AlwaysOnTop  = true
        bb.StudsOffset  = Vector3.new(0, 2, 0)
        bb.MaxDistance  = 150
        bb.Adornee      = head
        bb.Parent       = ScreenGui

        local nameLbl = Instance.new("TextLabel", bb)
        nameLbl.Size                  = UD2(0, 100, 0, 20)
        nameLbl.Position              = UD2(-0.5, 0, -1, 0)
        nameLbl.BackgroundTransparency= 1
        nameLbl.Text                  = player.DisplayName
        nameLbl.TextColor3            = COL_WHITE
        nameLbl.TextStrokeTransparency= 0
        nameLbl.Font                  = Enum.Font.GothamBlack
        nameLbl.TextSize              = 12
        ESPObjects[player].billboard  = bb
    end

    buildForChar(player.Character)
    local charConn = player.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        buildForChar(char)
    end)
    ESPObjects[player].charConn = charConn
end

ESPBtn.MouseButton1Click:Connect(function()
    State.ESP = not State.ESP
    animateToggle(State.ESP, ESPTrack, ESPKnob)

    if State.ESP then
        for _, player in ipairs(Players:GetPlayers()) do
            addESP(player)
        end
    else
        for player in pairs(ESPObjects) do
            removeESP(player)
        end
    end
end)

Players.PlayerAdded:Connect(function(player)
    if State.ESP then addESP(player) end
end)

Players.PlayerRemoving:Connect(function(player)
    removeESP(player)
end)

